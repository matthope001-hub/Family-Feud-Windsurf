            <!-- Share modal -->
<div class="modal fade" id="soundModal" tabindex="-1" role="dialog" aria-labelledby="soundModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="soundModalLabel" v-on:click="triggerPlaySound(selectedSound)">
                    <span class="fas fa-fw fa-play"></span> {{ selectedSound.sound_transcript }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <div class="d-flex sound-modal-buttons">
                    <div>
                        <button class="btn btn-large btn-primary" v-on:click="triggerPlaySound(selectedSound)">
                            <i class="fas fa-fw fa-play"></i><br />Play<br /></button>
                    </div>

                    <div class="ps-2">
                        <button class="btn btn-large btn-primary text-white"
                            v-on:click="triggerDownloadSound(selectedSound)">
                            <i class="fas fa-fw fa-download"></i><br />Download MP3</button>
                    </div>

                    <div class="ps-2">
                        <button class="btn btn-large btn-warning" v-on:click="addToFavorites(selectedSound)"
                            role="button" aria-label="Add this sound to your Favorites Board" data-bs-toggle="tooltip"
                            title="Add this sound to your Favorites board">
                            <i class="fas fa-fw fa-star"></i><br />Favorite</button>
                    </div>

                    <div class="ps-2 share-buttons">
                        <!-- Sharing is dynamically added here -->
                    </div>
                </div>

                <div class="d-flex sound-modal-buttons mt-3 me-3">
                    <input type="text" readonly class="form-control w-100" id="share-link" value="">
                </div>

                <div class="d-flex sound-modal-buttons mt-3">
                    <button class="btn btn-large btn-primary" id="share-copy-link" role="button" aria-label="Copy Link"
                        data-bs-toggle="tooltip" title="Copy Link">
                        <i class="fas fa-fw fa-copy"></i><br />Copy Link<br />
                    </button>

                    <a href="#" id="share-go-to-sound">
                        <button class="btn btn-large btn-success ms-2" role="button" aria-label="Go To Sound Page"
                            data-bs-toggle="tooltip" title="Go to Sound Page">
                            <i class="fas fa-fw fa-right-long"></i>
                            <i class="fas fa-fw fa-link"></i><br />Go to Sound Page<br />
                        </button>
                    </a>

                    <a href="#" id="share-go-to-board">
                        <button class="btn btn-large btn-success ms-2" role="button" aria-label="Go To Board Page"
                            data-bs-toggle="tooltip" title="Go to Board Page">
                            <i class="fas fa-fw fa-right-long"></i>
                            <i class="fas fa-fw fa-link"></i><br />Go to Board Page<br />
                        </button>
                    </a>

                    <button class="btn btn-large btn-danger ms-2" v-on:click="report(selectedSound)" role="button"
                        aria-label="Report sound as offensive" data-bs-toggle="tooltip"
                        title="Report sound as offensive">
                        <i class="fa fa-flag"></i><br />Report
                    </button>

                    <div class="d-none d-md-block ms-2">
                        <a href="/favorites/me">
                            <button class="btn btn-large btn-success" role="button"
                                aria-label="Go to Your Favorites board" data-bs-toggle="tooltip"
                                title="Go to Your Favorites board">
                                <i class="fa fa-table"></i><br />My Favorites</button>
                        </a>
                    </div>
                </div>

                
                

                <hr />

                <button class="btn btn-large btn-outline-dark ms-2" href="#" disabled>
                    Plays: {{ Number(selectedSound.sound_hits).toLocaleString() }}
                </button>

                <button class="btn btn-large btn-outline-dark ms-2" href="#" disabled>
                    Downloads: {{ Number(selectedSound.sound_downloads).toLocaleString() }}
                </button>

            </div>
        </div>
    </div>
</div>
            

