            "or": [
                { "href_matches": "/boards/*" },
                { "href_matches": "/tts/*" },
                { "href_matches": "/sounds/*" },
                { "href_matches": "/pages/*" },
                { "href_matches": "/blog/*" },
                { "href_matches": "/changelog" },
                { "href_matches": "/mp3-trimmer" },
                { "href_matches": "/convert" },
                { "href_matches": "/tags" },
                { "href_matches": "/tags/*" },
                { "href_matches": "/featured/*" },
                { "href_matches": "/users/*" },
                { "href_matches": "/search" },
                { "href_matches": "/" }
            ]
        },
        "eagerness": "moderate"
        }
    ]
    }
    </script>

    

    

